# Copy to .env and edit. The watcher auto-loads .env (real environment values
# take precedence). NEVER commit your filled-in .env — it holds secrets.

# ===================== core =====================
WATCHER_DB_PATH=./watcher.db
WATCHER_SOURCE_URL=https://www.dailywarden.com/

# Enabled sources (comma-separated). Built-ins:
#   dailywarden - aggregated contests (start times -> t24h alerts)
#   sherlock    - Sherlock audit contests via public API (start times -> t24h)
#   immunefi    - Immunefi bug bounties (perpetual) AND audit competitions
#                 (time-boxed, t24h); both surfaces fetched by this one source
#   cantina     - Cantina bounties (perpetual) AND competitions (time-boxed, t24h)
#   sch         - smartcontractshacking.com aggregator; adds HackenProof (incl.
#                 bounties) + Code4rena + CodeHawks. Skips platforms covered
#                 directly (sherlock/cantina/immunefi) to avoid duplicates.
#   discord     - relays announcements you've Followed into your own Discord
#                 server (kind=announcement; new-listing alerts only). Needs the
#                 two DISCORD_* vars below. See README "Discord source setup".
# A broken source never silences the others; you just get a warning about it.
WATCHER_SOURCES=dailywarden,sherlock,immunefi

# --- Discord SOURCE (reading) — distinct from the Discord NOTIFIER (sending) ---
# Bot token from the Discord Developer Portal (Bot tab). Message Content Intent ON.
# Comma-separated channel IDs in YOUR server where platform Follows cross-post.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=

# Preview mode: compute & print alerts without sending or persisting anything.
WATCHER_DRY_RUN=0

# 24h alert window in seconds. Enlarge temporarily to force-test the t24h path.
WATCHER_T24H_SECONDS=86400

# ===================== channel selection =====================
# One built-in, several comma-separated (fan-out), or a "module:Class" plugin.
# Built-ins: console | smtp | gmail | discord | slack | telegram | webhook
# Examples:
#   WATCHER_NOTIFIER=telegram
#   WATCHER_NOTIFIER=discord,smtp
#   WATCHER_NOTIFIER=my_pkg.notifiers:PagerDutyNotifier
WATCHER_NOTIFIER=console

# --- email (smtp / gmail) ---
# Gmail: use a Google App Password (https://myaccount.google.com/apppasswords).
# Port 465 = implicit TLS; 587 = STARTTLS.
# WATCHER_RECIPIENT may be a single address or several, comma-separated.
WATCHER_RECIPIENT=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# --- discord (Server Settings > Integrations > Webhooks) ---
DISCORD_WEBHOOK_URL=

# --- slack (Incoming Webhooks app) ---
SLACK_WEBHOOK_URL=

# --- telegram (@BotFather token + your chat id) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- generic webhook (POSTs {subject, body, text}) ---
WEBHOOK_URL=
WEBHOOK_TOKEN=          # optional -> sent as "Authorization: Bearer <token>"
